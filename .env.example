# Copy this file to `.env` and fill in the values you need.
# Most scripts and workbooks run with only OPENAI_API_KEY.

# Core LLM key used by most examples, notebooks, and workbooks:
# 1, 4, 5, 6, 10, 11, 12, 13, 14, 15
OPENAI_API_KEY=

# Optional OpenRouter key used by:
# 3-prospect-agent, 8-new-idea-gen, 9-prospect-searx
# Leave blank unless you want those examples to use OpenRouter-backed models.
OPENROUTER_API_KEY=

# Web search key used by:
# 2-multi-tool-rag, 8-new-idea-gen
# Optional for 3-prospect-agent when you want Brave instead of the default ddg flow.
BRAVE_API_KEY=

# Qdrant cloud settings for:
# 2-multi-tool-rag
# scripts/clear_qdrant.py
QDRANT_URL=
QDRANT_KEY=

# Redis connection string for:
# 7-redis-rag
# Local default works with: docker run -p 6379:6379 -d redis
REDIS_URL=redis://localhost:6379

# SearXNG settings for:
# 9-prospect-searx
# Local default works with the Docker setup in that example README.
SEARXNG_HOST=http://localhost:8888
SEARXNG_DEBUG=false

# Search tuning used by:
# 3-prospect-agent, 9-prospect-searx
SEARCH_WAIT_SECONDS=1.0

# Search provider selection for:
# 3-prospect-agent
# Valid values depend on the implementation; `ddg` is the safe default here.
PREFERRED_SEARCH_PROVIDER=ddg
