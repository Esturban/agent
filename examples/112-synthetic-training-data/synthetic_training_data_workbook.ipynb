from collections import Counter

label_counts: Counter = Counter()
with open("/tmp/full_pipeline_output.jsonl") as f:
    for line in f:
        row = json.loads(line)
        # The assistant turn (last message) holds the label
        label = row["messages"][-1]["content"]
